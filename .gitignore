# =============================================================================
# Lumina — .gitignore (Vercel + local dev + Capacitor iOS)
# Secrets go in Vercel Dashboard → Settings → Environment Variables, not git.
# =============================================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js / build output ---
/.next/
/out/
/build
/dist
.swc/

# --- Vercel ---
.vercel
.vercel/*

# --- Environment & secrets (never commit) ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# Safe templates (commit these)
!env.example
!.env.example
!.env.local.example

# Keys & certs
*.pem
*.p8
AuthKey_*.p8
secrets/

# --- Local dev data (JSON storage fallback) ---
.data/

# --- Research / scratch ---
.research/

# --- Testing ---
/coverage

# --- Logs & OS junk ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Capacitor / iOS (commit ios/ source; ignore build noise) ---
ios/App/Pods/
ios/App/build/
ios/App/output/
ios/DerivedData/
ios/App/App/public/
ios/App/App/capacitor.config.json
ios/App/App/config.xml
ios/capacitor-cordova-ios-plugins/
*.xcuserstate
*.xcuserdata
*.ipa
*.dSYM.zip
*.moved-aside