# Magic Labs — embedded wallet (bonus track; primary auth when set)
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# Tavily AI — Care Compass live research (free tier at tavily.com)
TAVILY_API_KEY=

# Particle Network — Universal Accounts (optional cross-chain)
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_APP_ID=

# Payout treasury on Arbitrum
NEXT_PUBLIC_UA_TREASURY=

# WalletConnect (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# App URL for SIWE + portal signatures
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session signing
JWT_SECRET=

# Storage: ipfs (default when PINATA_JWT set) | json | postgres
STORAGE_MODE=ipfs

# IPFS — wallet-owned care graph (Pinata free tier)
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Legacy postgres (optional — STORAGE_MODE=postgres)
DATABASE_URL=
DATABASE_SSL=false

# On-chain settlement verification
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
SETTLEMENT_WEBHOOK_SECRET=

# Portal EIP-712 domain chain (Arbitrum = 42161)
PORTAL_SIGN_CHAIN_ID=42161

# Dev-only simulated settlements (default off — use real Magic USDT transfers)
ALLOW_DEMO_SETTLEMENT=false

# Chain mode: false = Arbitrum One mainnet (real USDT) | true = Sepolia testnet (free faucet)
NEXT_PUBLIC_USE_TESTNET=false

# Arbitrum RPC for balance reads (client + server)
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Autopilot cron
CRON_SECRET=