# Magic Labs (required for bonus track)
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# Tavily AI — Care Compass live research (optional)
TAVILY_API_KEY=

# Treasury — USDT recipient on Arbitrum One mainnet
NEXT_PUBLIC_UA_TREASURY=

# Chain: false = Arbitrum One (real USDT) | true = Sepolia testnet (free faucet)
NEXT_PUBLIC_USE_TESTNET=false

# Session + cron (required in production)
JWT_SECRET=
CRON_SECRET=

# App URL for OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebAuthn / Face ID (optional — auto-detected on Vercel)
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# Arbitrum RPC (client balance reads + server verification)
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# IPFS care graph (optional — Pinata)
PINATA_JWT=
STORAGE_MODE=ipfs

# Dev-only simulated settlements (keep false for real USDT)
ALLOW_DEMO_SETTLEMENT=false

# Particle Universal Accounts (optional fallback)
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_APP_ID=

# Capacitor / TestFlight (production HTTPS URL for native iOS shell)
CAPACITOR_SERVER_URL=https://your-app.vercel.app
IOS_BUNDLE_ID=app.lumina.care