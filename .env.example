# =============================================================================
# Lumina — Environment Variables
# =============================================================================
# Copy to .env.local for local dev / Capacitor builds:
#   cp .env.example .env.local
#
# TestFlight path:
#   1. Deploy backend to Vercel with the REQUIRED + RECOMMENDED vars below
#   2. Set CAPACITOR_SERVER_URL + IOS_BUNDLE_ID locally, then npm run ios:prepare
#   3. Magic Dashboard + Apple Developer: Apple/Google OAuth (no env vars for Apple)
#
# Chain: Arbitrum One MAINNET (chain ID 42161). Keep NEXT_PUBLIC_USE_TESTNET=false.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — Magic embedded wallet (primary auth)
# -----------------------------------------------------------------------------
# dashboard.magic.link → your Embedded Wallet app
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_xxxxxxxx
MAGIC_SECRET_KEY=sk_live_xxxxxxxx

# Public HTTPS origin — must match deployed URL (Vercel) or ngrok for mobile dev.
# Used for OAuth redirect, SIWE, WebAuthn fallback, Magic allowlist.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Magic Dashboard allowlist sync (run after changing NEXT_PUBLIC_APP_URL):
#   node scripts/magic-setup-allowlist.mjs
# Also add redirect: {NEXT_PUBLIC_APP_URL}/login/oauth
# Apple Sign In: configure Service ID / Key in Magic Dashboard (not in .env).


# -----------------------------------------------------------------------------
# REQUIRED — Session & secrets (generate strong random values for production)
# -----------------------------------------------------------------------------
# openssl rand -base64 32
JWT_SECRET=
CRON_SECRET=


# -----------------------------------------------------------------------------
# REQUIRED — Mainnet chain (Arbitrum One, real USDT)
# -----------------------------------------------------------------------------
# MUST stay false for TestFlight / production. Only true for local Sepolia experiments.
NEXT_PUBLIC_USE_TESTNET=false

# USDT payout treasury on Arbitrum One (0x… checksummed address)
NEXT_PUBLIC_UA_TREASURY=0x0000000000000000000000000000000000000000

# Arbitrum One RPC — client balance reads + server settlement verification
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# EIP-712 portal signatures — 42161 = Arbitrum One mainnet
PORTAL_SIGN_CHAIN_ID=42161

# MUST stay false in production — blocks simulated/fake settlements
ALLOW_DEMO_SETTLEMENT=false


# -----------------------------------------------------------------------------
# REQUIRED — WebAuthn / Face ID (production & TestFlight)
# -----------------------------------------------------------------------------
# Hostname only (no https://). Must match NEXT_PUBLIC_APP_URL host.
WEBAUTHN_RP_ID=your-app.vercel.app
WEBAUTHN_ORIGIN=https://your-app.vercel.app


# -----------------------------------------------------------------------------
# REQUIRED — TestFlight / Capacitor iOS shell (local build machine)
# -----------------------------------------------------------------------------
# Production HTTPS URL loaded inside the native app (same as NEXT_PUBLIC_APP_URL).
CAPACITOR_SERVER_URL=https://your-app.vercel.app

# Apple Developer App ID — must match Xcode + App Store Connect
IOS_BUNDLE_ID=app.lumina.care


# -----------------------------------------------------------------------------
# RECOMMENDED — Data persistence (Vercel serverless has no local disk)
# -----------------------------------------------------------------------------
STORAGE_MODE=ipfs
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs


# -----------------------------------------------------------------------------
# RECOMMENDED — Care Compass live AI research
# -----------------------------------------------------------------------------
TAVILY_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — Email notifications (family portal alerts)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=Lumina <onboarding@resend.dev>


# -----------------------------------------------------------------------------
# OPTIONAL — Settlement webhook (external payment confirmation)
# -----------------------------------------------------------------------------
SETTLEMENT_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# OPTIONAL — Particle Universal Accounts (fallback when Magic keys unset)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_APP_ID=


# -----------------------------------------------------------------------------
# OPTIONAL — WalletConnect (legacy wallet login path)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=


# -----------------------------------------------------------------------------
# OPTIONAL — Postgres storage (default is IPFS or JSON)
# -----------------------------------------------------------------------------
DATABASE_URL=
DATABASE_SSL=false


# -----------------------------------------------------------------------------
# DEV ONLY — Sepolia testnet (do NOT set on Vercel / TestFlight)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_USE_TESTNET=true
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org
# SEPOLIA_RPC_URL=https://rpc.sepolia.org